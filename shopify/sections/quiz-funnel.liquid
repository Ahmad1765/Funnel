						      <div
						        data-block-id="html-fa65bb6e"
						      ><div><div class="hidedate" style="display:none;">
						  <span class="variable-replace" data-variable="eventDate"></span>
						</div>
						<div id="version-soon" style="display: none; text-align: center;">
						  <p style="text-align:center;">✅ Zichtbare vermindering van rimpels en fijne lijnen voor jouw
						 <span class="variable-replace" data-variable="EventName"></span></p>
						  <p style="text-align:center;">✅ Rimpels zichtbaar verminderd & slappe huid aangetrokken tot <span id="future-date"></span></p>
						</div>
						<div id="version-after" style="display: none; text-align: center;">
						<p style="text-align:center;">✅Zichtbare resultaten na slechts een toepassing
						</p>
						  <p>✅ Rimpels verwijderd en volledig aangetrokken huid tot <span id="future-date2"></span></p>
