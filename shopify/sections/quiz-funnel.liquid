						</div>
						
						<script>
						// Main function to handle dynamic dates
						function initDynamicDates() {
						  // Only run on #results1 page
						  if (window.location.hash !== "#results1") return;
						  
						  try {
						    // Get date directly from Heyflow's common data sources
						    let eventDate = getHeyflowDate();
						    
						    // If still not found, try other common methods
						if (!eventDate) {
						      eventDate = getAlternativeDate();
						
						    }
						    // Validate we have a date
						    if (!eventDate) {
						throw new Error("No event date found");
						    }
						
						    
						    console.log("Found event date:", eventDate);
						    
						    // Parse dates (DD/MM/YYYY format - FIXED!)
						    const [day, month, year] = eventDate.split('/').map(Number);
						    const eventDateObj = new Date(year, month - 1, day);
						    
						    if (isNaN(eventDateObj.getTime())) {
						      throw new Error("Invalid event date format");
						    }
						    
						    // Calculate comparison dates
						    const today = new Date();
						    today.setHours(0, 0, 0, 0); // Reset time to start of day for accurate comparison
						    
						    const threeMonthsLater = new Date(today);
						    threeMonthsLater.setMonth(today.getMonth() + 3);
						    
						    // Format display date (3 months from now)
						    const formatDate = (date) => {
						      return [
						        (date.getMonth() + 1).toString().padStart(2, '0'),
						        date.getDate().toString().padStart(2, '0'),
						        date.getFullYear()
						      ].join('/');
						    };
						    const displayDate = formatDate(threeMonthsLater);
						    
						    // Update all date displays
						    document.querySelectorAll('#future-date, #future-date2').forEach(el => {
						      el.textContent = displayDate;
						    });
						    
						    // CORRECTED LOGIC:
						    // If event date is WITHIN 3 months from now (less than or equal to threeMonthsLater)
						    // → Show "version-soon"
						    // If event date is MORE than 3 months from now
						    // → Show "version-after"
						    const showSection = eventDateObj <= threeMonthsLater ? "version-soon" : "version-after";
						    document.getElementById(showSection).style.display = 'block';
						    
						    console.log("Event Date:", eventDateObj.toDateString());
						    console.log("Today:", today.toDateString());
						    console.log("3 Months Later:", threeMonthsLater.toDateString());
						    console.log("Showing section:", showSection);
						    
						  } catch (error) {
						    console.error("Date initialization failed:", error.message);
						    // Fallback: Show both versions if there's an error
						    document.getElementById("version-soon").style.display = 'block';
						    document.getElementById("version-after").style.display = 'block';
						  }
						}
						
						// Get date from Heyflow's most common data sources
						function getHeyflowDate() {
						  // Method 1: Check Heyflow's form data
						  if (window.heyflow && window.heyflow.formData) {
						    for (const field in window.heyflow.formData) {
						      if (field.toLowerCase().includes('date') || field.toLowerCase().includes('event')) {
						        console.log("Found date in Heyflow form data:", window.heyflow.formData[field]);
						        return window.heyflow.formData[field];
						      }
						    }
						  }
						  
						  // Method 2: Check URL parameters
						  const urlParams = new URLSearchParams(window.location.search);
						  if (urlParams.has('eventDate')) {
						    console.log("Found date in URL parameters");
						    return urlParams.get('eventDate');
						  }
						  
						  // Method 3: Check form fields directly
						  const dateField = document.querySelector('input[name*="date"], input[name*="event"]');
						  if (dateField && dateField.value) {
						    console.log("Found date in form field");
						    return dateField.value;
						  }
						  
						  return null;
						}
						
						// Alternative methods to get the date
						function getAlternativeDate() {
						  // Method 4: Check session storage
						  if (sessionStorage.getItem('eventDate')) {
						    console.log("Found date in session storage");
						    return sessionStorage.getItem('eventDate');
						  }
						  
						  // Method 5: Check local storage
						  if (localStorage.getItem('eventDate')) {
						    console.log("Found date in local storage");
						    return localStorage.getItem('eventDate');
